PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Use your own MongoDB Atlas/local connection string here.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/smartstore_ai?retryWrites=true&w=majority

# Generate a long random value and keep the real one only in backend/.env1`_chars

# Optional for later AI features. Leave blank until the assistant route calls OpenAI.
OPENAI_API_KEY=
