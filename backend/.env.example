PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Use your own MongoDB Atlas/local connection string here.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/smartstore_ai?retryWrites=true&w=majority

# Generate a long random value and keep the real one only in backend/.env.
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Required for Phase 5 AI content generation with Gemini.
GEMINI_API_KEY=

# Optional Gemini tuning.
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=20000
