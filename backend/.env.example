PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
JSON_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30

# Use your own MongoDB Atlas/local connection string here.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/smartstore_ai?retryWrites=true&w=majority

# Generate a long random value and keep the real one only in backend/.env.
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Required for AI content generation and Phase 7 business intelligence with Gemini.
GEMINI_API_KEY=

# Optional Gemini tuning.
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=30000
